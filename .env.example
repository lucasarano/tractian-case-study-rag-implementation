COPILOT_RUNTIME_ENV=local
COPILOT_AUTH_MODE=dev
COPILOT_VECTOR_BACKEND=pinecone
COPILOT_GENERATION_BACKEND=gemini
COPILOT_LOG_LEVEL=INFO

COPILOT_DEV_TENANT_ID=companyA
COPILOT_DEV_USER_ID=tech-001

COPILOT_DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/maintenance_copilot
COPILOT_REDIS_URL=redis://redis:6379/0

COPILOT_GOOGLE_PROJECT=
COPILOT_GOOGLE_LOCATION=us-central1
COPILOT_DOCUMENTAI_LOCATION=us
COPILOT_DOCUMENTAI_LAYOUT_PROCESSOR_ID=
COPILOT_DOCUMENTAI_OCR_PROCESSOR_ID=
# GOOGLE_APPLICATION_CREDENTIALS=/app/secrets/google-service-account.json
COPILOT_TEXT_EMBEDDING_MODEL=gemini-embedding-001
COPILOT_TEXT_EMBEDDING_DIMENSIONS=768
COPILOT_GENERATION_FLASH_MODEL=gemini-2.5-flash
COPILOT_GENERATION_PRO_MODEL=gemini-2.5-pro
COPILOT_RANKING_LOCATION=global
COPILOT_RANKING_CONFIG=default_ranking_config
COPILOT_RANKING_MODEL_FAST=semantic-ranker-fast@latest
COPILOT_RANKING_MODEL_DEFAULT=semantic-ranker-default@latest

COPILOT_PINECONE_API_KEY=
COPILOT_PINECONE_MANUAL_INDEX=oem-manuals
COPILOT_PINECONE_LOG_INDEX=historical-insights

# Switch to okta outside local development.
# COPILOT_AUTH_MODE=okta
# COPILOT_OKTA_ISSUER=https://your-org.okta.com/oauth2/default
# COPILOT_OKTA_AUDIENCE=api://maintenance-copilot

COPILOT_WORKER_POLL_INTERVAL_SECONDS=5
COPILOT_ENABLE_OTEL=false
COPILOT_LOCAL_ASSET_SEED_PATH=fixtures/assets.json
COPILOT_LOCAL_SAMPLE_MANUAL_REQUEST_PATH=fixtures/manual_job.json
COPILOT_LOCAL_SAMPLE_LOG_REQUEST_PATH=fixtures/log_incident.json
